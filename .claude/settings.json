{
    "hooks": {
      "Stop": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "graphify build \"${CLAUDE_PROJECT_DIR:-.}\" >/dev/null 2>&1 && mv \"${CLAUDE_PROJECT_DIR:-.}/graphify-out/graph.json\" \"${CLAUDE_PROJECT_DIR:-.}/docs/graphify-out/graph.json\" 2>/dev/null && rmdir \"${CLAUDE_PROJECT_DIR:-.}/graphify-out\" 2>/dev/null || true"
            }
          ]
        }
      ]
    }
}
